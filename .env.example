# BMEX Application Environment Configuration
# Copy this file to .env and update with your production values

# ============================================
# GENERAL SETTINGS
# ============================================
DEBUG=False
ENVIRONMENT=production

# ============================================
# SECURITY
# ============================================
# IMPORTANT: Generate a strong secret key for production
# You can generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ============================================
# DASH FRONTEND
# ============================================
DASH_DEBUG=False
API_BASE_URL=http://backend:8000/api

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Backend type: 'file' for SQLite or 'db' for PostgreSQL
BMEX_DATA_BACKEND=file
BMEX_DATA_PATH=/app/data

# PostgreSQL settings (only if BMEX_DATA_BACKEND=db)
DB_NAME=bmex
DB_USER=bmex_user
DB_PASSWORD=your-secure-database-password
DB_HOST=db
DB_PORT=5432

# ============================================
# CORS CONFIGURATION
# ============================================
# Frontend URLs allowed to access the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8050,http://127.0.0.1:8050,https://your-domain.com

# ============================================
# API RATE LIMITING
# ============================================
# Format: number/unit (e.g., 1000/hour, 100/minute, 10000/day)
THROTTLE_ANON=1000/hour
THROTTLE_USER=10000/hour

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
APP_LOG_LEVEL=INFO

# ============================================
# GUNICORN CONFIGURATION
# ============================================
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8000

# ============================================
# OPTIONAL: Google Analytics
# ============================================
# Uncomment and add your GA tracking ID if needed
# GA_TRACKING_ID=G-XXXXXXXXXX
